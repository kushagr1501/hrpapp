    "expo-server-sdk": "^6.1.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.5.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.3",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.9.0",
